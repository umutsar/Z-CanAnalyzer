<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212">

    <LinearLayout android:layout_width="match_parent" android:layout_height="56dp" android:orientation="horizontal" android:gravity="center_vertical" android:background="#1E1E1E" android:paddingStart="20dp" android:paddingEnd="20dp" android:elevation="4dp">
        <View android:layout_width="4dp" android:layout_height="24dp" android:background="#32a852" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:text="@string/app_name" android:textSize="18sp" android:textColor="#E0E0E0" android:textStyle="bold" android:letterSpacing="0.02" />
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:padding="16dp">
    <Button android:id="@+id/btnToggleConnect" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/btn_connect" android:backgroundTint="#4CAF50" android:textColor="#FFFFFF"/>
    <Button android:id="@+id/btnStopResume" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="@string/btn_pause" android:backgroundTint="#FF9800" android:textColor="#000000"/>
    <TextView android:id="@+id/tvStatus" android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="8dp" android:text="@string/status_disconnected" android:textColor="#FF5252" android:textSize="16sp" android:textStyle="bold" />

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="#1E1E1E" android:layout_marginTop="5dp">
        <LinearLayout android:id="@+id/txPanelBar" android:layout_width="match_parent" android:layout_height="48dp" android:orientation="horizontal" android:gravity="center_vertical" android:paddingStart="16dp" android:paddingEnd="16dp" android:background="#2D2D2D" android:clickable="true" android:focusable="true">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/tx_panel_bar" android:textSize="14sp" android:textColor="#E0E0E0" android:textStyle="bold" />
            <TextView android:id="@+id/txPanelChevron" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="▶" android:textSize="12sp" android:textColor="#B0BEC5" />
        </LinearLayout>
        <LinearLayout android:id="@+id/txPanelContent" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="8dp" android:visibility="gone">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/label_can_id" android:textSize="12sp" android:textColor="#B0BEC5" android:textStyle="bold" />
                <EditText android:id="@+id/etSendId" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="#2D2D2D" android:textColor="#E0E0E0" android:textColorHint="#757575" android:inputType="textCapCharacters" android:textSize="14sp" android:maxLength="8" android:padding="8dp" />
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="0.4" android:orientation="vertical" android:layout_marginStart="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/label_dlc" android:textSize="12sp" android:textColor="#B0BEC5" android:textStyle="bold" />
                <EditText android:id="@+id/etSendDlc" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="#2D2D2D" android:text="8" android:textColor="#E0E0E0" android:textColorHint="#757575" android:inputType="number" android:digits="12345678" android:maxLength="1" android:textSize="14sp" android:padding="8dp" />
            </LinearLayout>
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="bottom" android:layout_marginStart="8dp" android:paddingBottom="4dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/label_data_format" android:textSize="12sp" android:textColor="#B0BEC5" android:textStyle="bold" />
                <RadioGroup android:id="@+id/rgMode" android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal">
                    <RadioButton android:id="@+id/rbHex" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="HEX" android:textColor="#E0E0E0" android:buttonTint="#4CAF50" android:checked="true" android:textSize="12sp" />
                    <RadioButton android:id="@+id/rbDec" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="DEC" android:textColor="#E0E0E0" android:buttonTint="#4CAF50" android:textSize="12sp" />
                </RadioGroup>
            </LinearLayout>
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginTop="8dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/label_payload" android:textSize="12sp" android:textColor="#B0BEC5" android:textStyle="bold" />
            <GridLayout android:id="@+id/gridDataBytes" android:layout_width="match_parent" android:layout_height="wrap_content" android:columnCount="@integer/grid_data_column_count" android:layout_marginTop="4dp" android:useDefaultMargins="false" android:alignmentMode="alignBounds">
                <LinearLayout android:id="@+id/layoutD0" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:orientation="vertical" android:layout_marginEnd="4dp" android:layout_marginBottom="4dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="D0" android:textSize="11sp" android:textColor="#B0BEC5" />
                    <EditText android:id="@+id/etD0" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="#2D2D2D" android:textColor="#E0E0E0" android:textColorHint="#757575" android:gravity="center" android:textSize="12sp" android:maxLength="3" android:padding="8dp" />
                </LinearLayout>
                <LinearLayout android:id="@+id/layoutD1" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:orientation="vertical" android:layout_marginEnd="4dp" android:layout_marginBottom="4dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="D1" android:textSize="11sp" android:textColor="#B0BEC5" />
                    <EditText android:id="@+id/etD1" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="#2D2D2D" android:textColor="#E0E0E0" android:textColorHint="#757575" android:gravity="center" android:textSize="12sp" android:maxLength="3" android:padding="8dp" />
                </LinearLayout>
                <LinearLayout android:id="@+id/layoutD2" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:orientation="vertical" android:layout_marginEnd="4dp" android:layout_marginBottom="4dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="D2" android:textSize="11sp" android:textColor="#B0BEC5" />
                    <EditText android:id="@+id/etD2" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="#2D2D2D" android:textColor="#E0E0E0" android:textColorHint="#757575" android:gravity="center" android:textSize="12sp" android:maxLength="3" android:padding="8dp" />
                </LinearLayout>
                <LinearLayout android:id="@+id/layoutD3" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:orientation="vertical" android:layout_marginEnd="4dp" android:layout_marginBottom="4dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="D3" android:textSize="11sp" android:textColor="#B0BEC5" />
                    <EditText android:id="@+id/etD3" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="#2D2D2D" android:textColor="#E0E0E0" android:textColorHint="#757575" android:gravity="center" android:textSize="12sp" android:maxLength="3" android:padding="8dp" />
                </LinearLayout>
                <LinearLayout android:id="@+id/layoutD4" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:orientation="vertical" android:layout_marginEnd="4dp" android:layout_marginBottom="4dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="D4" android:textSize="11sp" android:textColor="#B0BEC5" />
                    <EditText android:id="@+id/etD4" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="#2D2D2D" android:textColor="#E0E0E0" android:textColorHint="#757575" android:gravity="center" android:textSize="12sp" android:maxLength="3" android:padding="8dp" />
                </LinearLayout>
                <LinearLayout android:id="@+id/layoutD5" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:orientation="vertical" android:layout_marginEnd="4dp" android:layout_marginBottom="4dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="D5" android:textSize="11sp" android:textColor="#B0BEC5" />
                    <EditText android:id="@+id/etD5" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="#2D2D2D" android:textColor="#E0E0E0" android:textColorHint="#757575" android:gravity="center" android:textSize="12sp" android:maxLength="3" android:padding="8dp" />
                </LinearLayout>
                <LinearLayout android:id="@+id/layoutD6" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:orientation="vertical" android:layout_marginEnd="4dp" android:layout_marginBottom="4dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="D6" android:textSize="11sp" android:textColor="#B0BEC5" />
                    <EditText android:id="@+id/etD6" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="#2D2D2D" android:textColor="#E0E0E0" android:textColorHint="#757575" android:gravity="center" android:textSize="12sp" android:maxLength="3" android:padding="8dp" />
                </LinearLayout>
                <LinearLayout android:id="@+id/layoutD7" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:orientation="vertical" android:layout_marginEnd="4dp" android:layout_marginBottom="4dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="D7" android:textSize="11sp" android:textColor="#B0BEC5" />
                    <EditText android:id="@+id/etD7" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="#2D2D2D" android:textColor="#E0E0E0" android:textColorHint="#757575" android:gravity="center" android:textSize="12sp" android:maxLength="3" android:padding="8dp" />
                </LinearLayout>
            </GridLayout>
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="8dp" android:gravity="center_vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/label_transmit_mode" android:textSize="12sp" android:textColor="#B0BEC5" android:textStyle="bold" />
            <RadioGroup android:id="@+id/rgSendMode" android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginStart="8dp">
                <RadioButton android:id="@+id/rbSingle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/rb_single_shot" android:textColor="#E0E0E0" android:buttonTint="#4CAF50" android:checked="true" android:textSize="12sp" />
                <RadioButton android:id="@+id/rbPeriodic" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/rb_periodic" android:textColor="#E0E0E0" android:buttonTint="#4CAF50" android:textSize="12sp" />
            </RadioGroup>
        </LinearLayout>
        <LinearLayout android:id="@+id/layoutInterval" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:visibility="gone" android:layout_marginTop="4dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/label_interval" android:textSize="12sp" android:textColor="#B0BEC5" android:textStyle="bold" />
            <EditText android:id="@+id/etIntervalMs" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="#2D2D2D" android:textColor="#E0E0E0" android:textColorHint="#757575" android:inputType="number" android:textSize="14sp" android:padding="8dp" />
        </LinearLayout>
        <Button android:id="@+id/btnSend" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="@string/btn_transmit" android:backgroundTint="#BB86FC" android:textColor="#000000"/>
        </LinearLayout>
    </LinearLayout>

    <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent" android:layout_marginTop="5dp">
        <ScrollView android:id="@+id/scrollView" android:layout_width="match_parent" android:layout_height="match_parent" android:background="#1E1E1E">
            <TextView android:id="@+id/tvLogs" android:layout_width="match_parent" android:layout_height="wrap_content" android:fontFamily="monospace" android:padding="8dp" android:text="@string/trace_waiting" android:textColor="#B0BEC5" android:textSize="12sp" />
        </ScrollView>
        <com.google.android.material.floatingactionbutton.FloatingActionButton android:id="@+id/fabScrollDown" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="bottom|end" android:layout_margin="16dp" android:src="@android:drawable/arrow_down_float" android:tint="#FFFFFF" android:visibility="gone" app:backgroundTint="#03DAC6" app:fabSize="mini" />
    </FrameLayout>
    </LinearLayout>
</LinearLayout>